# Copy this file to .env.local and fill in your values.
DEVMODE=true

# SSL certs
# only needed for production (DEVMODE=false)
KEYPATH=
CERTPATH=

# Vertex AI / Gemini TTS — service account credentials
# Place your service account JSON at server/key/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=./server/key/service-account.json
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash-tts

# Frontend
REACT_APP_PORT=8000
REACT_APP_API_BASE=http://localhost:8000
REACT_APP_PREVIEW_ONLY=false
