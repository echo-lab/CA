# TTS Backend: "gemini" (default) or "vertex"
TTS_BACKEND=gemini

# Development mode (true = HTTP, false/unset = HTTPS with certs)
DEVMODE=true

# Server port
REACT_APP_PORT=5001

# SSL certificates (production only)
KEYPATH=
CERTPATH=

# Google Cloud TTS (for /synthesize endpoint)
GOOGLEAPI_KEY=

# Gemini TTS backend (when TTS_BACKEND=gemini)
GEMINI_API_KEY=
# GEMINI_LIVE_MODEL=gemini-2.5-flash-preview-tts

# Vertex AI TTS backend (when TTS_BACKEND=vertex)
# VERTEX_PROJECT_ID=
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-2.5-flash-tts

# OpenAI (for realtime, relevancy, classification, educational questions)
OPENAI_API_KEY=

# Deepgram (for speech-to-text proxy)
DEEPGRAM_API_KEY=

REACT_APP_TTSURL=http://localhost/
